<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
  <id>odf-kit-service</id>
  <name>odf-kit Service</name>
  <summary>Export Markdown, HTML, and text files to ODT format</summary>
  <description>
    Export your Nextcloud files to the ISO standard ODT format (OpenDocument Text),
    used by LibreOffice, Microsoft Word, and government document systems worldwide.

    Supports Markdown, HTML, and plain text files. Choose your page format:
    A4 (Europe), Letter (USA), Legal, A3, or A5.

    Powered by odf-kit — a zero-dependency JavaScript library for ODF document generation.
    No LibreOffice required. Works entirely within your Nextcloud instance.
  </description>
  <version>0.4.0</version>
  <licence>agpl</licence>
  <author>Scott Wirth</author>
  <namespace>OdfKitService</namespace>
  <category>tools</category>
  <dependencies>
    <nextcloud min-version="30" max-version="34"/>
  </dependencies>
  <external-app>
    <docker-install>
      <registry>ghcr.io</registry>
      <image>githubnewbie0/odf-kit-service</image>
      <image-tag>0.4.0</image-tag>
    </docker-install>
    <scopes>
      <value>FILES</value>
    </scopes>
    <routes>
      <route>
        <url>/generate</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/fill</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/odt</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/html</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/typst</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/pdf</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/file-action</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>ui</url>
        <verb>GET</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[]</bruteforce_protection>
      </route>
      <route>
        <url>ui</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>img</url>
        <verb>GET</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[]</bruteforce_protection>
      </route>
    </routes>
  </external-app>
</info>
