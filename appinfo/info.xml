<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
  <id>odf-kit-service</id>
  <n>odf-kit Service</n>
  <summary>ODF document generation and conversion service</summary>
  <description>
    Exposes odf-kit as a shared HTTP service for other ExApps.
    Provides document generation, template filling, HTML conversion,
    Typst conversion, and PDF export.
  </description>
  <version>0.1.0</version>
  <licence>agpl</licence>
  <author>Scott Wirth</author>
  <namespace>OdfKitService</namespace>
  <category>tools</category>
  <dependencies>
    <nextcloud min-version="30" max-version="33"/>
  </dependencies>
  <external-app>
    <docker-install>
      <registry>ghcr.io</registry>
      <image>githubnewbie0/odf-kit-service</image>
      <image-tag>latest</image-tag>
    </docker-install>
    <scopes>
      <value>FILES</value>
    </scopes>
    <routes>
      <route>
        <url>/generate</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/fill</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/html</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/typst</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
      <route>
        <url>/convert/pdf</url>
        <verb>POST</verb>
        <access_level>USER</access_level>
        <headers_to_exclude>[]</headers_to_exclude>
        <bruteforce_protection>[401, 500]</bruteforce_protection>
      </route>
    </routes>
  </external-app>
</info>
